// TSConfig for AudioWorklet processors, which run in the `AudioWorkletGlobalScope`
// rather than the DOM. `@types/audioworklet` supplies that scope's globals
// (`registerProcessor`, `sampleRate`, `AudioWorkletProcessor`, ...) and ships its
// own minimal lib, so the DOM lib is intentionally left out to avoid clashes.
{
  "compilerOptions": {
    "composite": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext"],
    "types": ["@types/audioworklet"],

    "strict": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noEmit": true,

    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.worklet.tsbuildinfo"
  },
  "include": ["src/audio/worklets/**/*"]
}
